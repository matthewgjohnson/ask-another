{
  "ask-another": {
    "command": "uvx",
    "args": ["--from", "git+https://github.com/matthewgjohnson/ask-another", "ask-another"],
    "env": {
      "PROVIDER_OPENAI": "${user_config.provider_openai}",
      "PROVIDER_GEMINI": "${user_config.provider_gemini}",
      "PROVIDER_OPENROUTER": "${user_config.provider_openrouter}",
      "ZERO_DATA_RETENTION": "${user_config.zero_data_retention}",
      "OPEN_GENERATED_IMAGES": "${user_config.open_generated_images}",
      "CACHE_TTL_MINUTES": "360"
    }
  }
}
